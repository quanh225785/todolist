# Environment example for frontend
# Copy to `.env` and fill values for your environment

# Base API URL (no trailing slash). Set to your public hostname, e.g. https://a.linhng148.id.vn
# DO NOT include an extra prefix like /a — frontend assumes endpoints start at `/api`.
VITE_API_URL=https://a.linhng148.id.vn
# Optional: URL to payment server (if using the included payment-server microservice)
VITE_SEPAY_SERVER=http://localhost:4000

# WebSocket URL (ws:// or wss://)
VITE_WS_URL=

# Optional dev proxy target for Vite server (e.g. http://localhost:8081)
VITE_PROXY_TARGET=
